# Frontend Environment Variables Example
# Copy this file to .env and fill in your actual values

# API URL - Backend server
VITE_API_URL=http://localhost:5000

# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=AIzaSyCwQx2DfJMhzn-EMUer_cnp-ZtiIe5Poes
# Razorpay Payment Gateway (Optional)
# Get from: https://dashboard.razorpay.com/
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Google Dialogflow for AI Chatbot (Future Enhancement)
VITE_DIALOGFLOW_PROJECT_ID=your_dialogflow_project_id

# Other Configuration
VITE_ENABLE_VOICE_SEARCH=true
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_MAPS=true
